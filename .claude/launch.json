{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "portal",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "7823", "--directory", "portal"],
      "port": 7823
    },
    {
      "name": "portal-alt",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-c", "import os,functools;from http.server import ThreadingHTTPServer,SimpleHTTPRequestHandler;h=functools.partial(SimpleHTTPRequestHandler,directory='portal');ThreadingHTTPServer(('127.0.0.1',int(os.environ.get('PORT','7824'))),h).serve_forever()"],
      "autoPort": true
    }
  ]
}
